<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Usuários</title>
  @vite(['resources/css/app.css', 'resources/js/app.js'])
</head>
<body class="bg-gray-50 text-gray-900 antialiased">
  @component('components/sidebar', { user, currentUrl: '/users' })
  @endcomponent

  <div class="md:ml-64 min-h-screen">
    @component('components/navbar', { user })
    @endcomponent

    <main class="p-4 md:p-6">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-gray-900">Usuários</h2>
        @can('usersCreate')
          <a href="/users/create" class="inline-flex items-center gap-2 bg-violet-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-violet-700 transition-colors">
            @component('components/icon', { name: 'plus', cssClass: 'w-4 h-4' })
            @endcomponent
            Novo Usuário
          </a>
        @endcan
      </div>

      @if(flashMessages.has('success'))
        <div class="mb-4 p-3 bg-green-50 border border-green-200 rounded text-green-700 text-sm">
          {{ flashMessages.get('success') }}
        </div>
      @endif

      <form method="GET" action="/users" class="mb-4 flex gap-2">
        <input type="text" name="search" value="{{ search }}" placeholder="Buscar por nome ou email..." class="flex-1 rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-violet-500 focus:ring-1 focus:ring-violet-500">
        <button type="submit" class="inline-flex items-center gap-2 bg-violet-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-violet-700 transition-colors">
          @component('components/icon', { name: 'magnifying-glass', cssClass: 'w-4 h-4' })
          @endcomponent
          Buscar
        </button>
        @if(search)
          <a href="/users" class="inline-flex items-center gap-1 bg-white text-gray-700 px-4 py-2 rounded-md text-sm font-medium border border-gray-300 hover:bg-gray-50 transition-colors">
            Limpar
          </a>
        @endif
      </form>

      <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Nome</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Perfil</th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Ações</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              @each(u in users)
                <tr>
                  <td class="px-6 py-4 text-sm font-medium text-gray-900">{{ u.fullName || '-' }}</td>
                  <td class="px-6 py-4 text-sm text-gray-500">{{ u.email }}</td>
                  <td class="px-6 py-4 text-sm text-gray-500">{{ u.profile ? u.profile.name : '-' }}</td>
                  <td class="px-6 py-4 text-right space-x-1">
                    @can('usersRead')
                      <a href="/users/{{ u.id }}" class="inline-flex items-center justify-center p-1.5 rounded-md text-violet-600 hover:text-violet-800 hover:bg-violet-50" title="Visualizar">
                        @component('components/icon', { name: 'eye', cssClass: 'w-4 h-4' })
                        @endcomponent
                      </a>
                    @endcan
                    @can('usersUpdate')
                      <a href="/users/{{ u.id }}/edit" class="inline-flex items-center justify-center p-1.5 rounded-md text-gray-500 hover:text-gray-700 hover:bg-gray-100" title="Editar">
                        @component('components/icon', { name: 'pencil', cssClass: 'w-4 h-4' })
                        @endcomponent
                      </a>
                    @endcan
                    @can('usersDelete')
                      <form action="/users/{{ u.id }}" method="POST" class="inline" onsubmit="return confirm('Tem certeza que deseja excluir este usuário?')">
                        {{ csrfField() }}
                        <input type="hidden" name="_method" value="DELETE">
                        <button type="submit" class="inline-flex items-center justify-center p-1.5 rounded-md text-red-500 hover:text-red-700 hover:bg-red-50" title="Excluir">
                          @component('components/icon', { name: 'trash', cssClass: 'w-4 h-4' })
                          @endcomponent
                        </button>
                      </form>
                    @endcan
                  </td>
                </tr>
              @else
                <tr>
                  <td colspan="4" class="px-6 py-4 text-center text-sm text-gray-500">Nenhum usuário encontrado</td>
                </tr>
              @endeach
            </tbody>
          </table>
        </div>
      </div>

      @if(users.lastPage > 1)
        <div class="flex items-center justify-between mt-4">
          <p class="text-sm text-gray-500">
            Mostrando {{ firstItem }}-{{ lastItem }} de {{ users.total }}
          </p>
          <div class="flex gap-1">
            @if(users.currentPage > 1)
              <a href="/users?page={{ users.currentPage - 1 }}{{ search ? '&search=' + search : '' }}" class="px-3 py-1 text-sm border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50">
                @component('components/icon', { name: 'chevron-left', cssClass: 'w-4 h-4' })
                @endcomponent
              </a>
            @endif
            @each(page in pages)
              @if(page === users.currentPage)
                <span class="px-3 py-1 text-sm border border-violet-600 bg-violet-50 text-violet-700 rounded-md font-medium">{{ page }}</span>
              @else
                <a href="/users?page={{ page }}{{ search ? '&search=' + search : '' }}" class="px-3 py-1 text-sm border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50">{{ page }}</a>
              @endif
            @endeach
            @if(users.currentPage < users.lastPage)
              <a href="/users?page={{ users.currentPage + 1 }}{{ search ? '&search=' + search : '' }}" class="px-3 py-1 text-sm border border-gray-300 rounded-md text-gray-700 hover:bg-gray-50">
                @component('components/icon', { name: 'chevron-right', cssClass: 'w-4 h-4' })
                @endcomponent
              </a>
            @endif
          </div>
        </div>
      @endif
    </main>
  </div>

  <script>
  function toggleSidebar() {
    const sidebar = document.getElementById('sidebar')
    const overlay = document.getElementById('sidebar-overlay')
    sidebar.classList.toggle('-translate-x-full')
    overlay.classList.toggle('hidden')
  }
  </script>
</body>
</html>