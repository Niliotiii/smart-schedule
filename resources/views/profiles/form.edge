<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ profile ? 'Editar Perfil' : 'Novo Perfil' }}</title>
  @vite(['resources/css/app.css', 'resources/js/app.js'])
</head>
<body class="bg-gray-50 text-gray-900 antialiased">
  @component('components/sidebar', { user, currentUrl: '/profiles' })
  @endcomponent

  <div class="md:ml-64 min-h-screen">
    @component('components/navbar', { user })
    @endcomponent

    <main class="p-4 md:p-6">
      <div class="mb-6 flex items-center gap-4">
        <a href="/profiles" class="text-gray-500 hover:text-gray-700">
          @component('components/icon', { name: 'chevron-left', cssClass: 'w-5 h-5' })
          @endcomponent
        </a>
        <h2 class="text-2xl font-bold text-gray-900">{{ profile ? 'Editar Perfil' : 'Novo Perfil' }}</h2>
      </div>

      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 max-w-2xl">
        <form action="{{ profile ? '/profiles/' + profile.id + '?_method=PUT' : '/profiles' }}" method="POST">
          {{ csrfField() }}

          <div class="space-y-4">
            <div>
              <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Nome</label>
              <input type="text" name="name" id="name" required
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-violet-500"
                value="{{ old('name', profile ? profile.name : '') }}">
              @error('name')
                <p class="mt-1 text-sm text-red-600">{{ $message }}</p>
              @enderror
            </div>

            <div>
              <label for="description" class="block text-sm font-medium text-gray-700 mb-1">Descrição</label>
              <textarea name="description" id="description" rows="3"
                class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-violet-500">{{ old('description', profile ? profile.description || '' : '') }}</textarea>
              @error('description')
                <p class="mt-1 text-sm text-red-600">{{ $message }}</p>
              @enderror
            </div>

            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Permissões</label>
              @each(module in Object.keys(groupedPermissions))
                <div class="mb-3">
                  <h4 class="text-sm font-medium text-gray-600 capitalize mb-2">{{ module }}</h4>
                  <div class="flex flex-wrap gap-3">
                    @each(perm in groupedPermissions[module])
                      <label class="inline-flex items-center gap-2 text-sm text-gray-700">
                        <input type="checkbox" name="permissionIds[]" value="{{ perm.id }}"
                          {{ selectedPermissionIds && selectedPermissionIds.includes(perm.id) ? 'checked' : '' }}
                          class="rounded border-gray-300 text-violet-600 focus:ring-violet-500">
                        {{ perm.action }}
                      </label>
                    @endeach
                  </div>
                </div>
              @endeach
            </div>

            <div class="flex gap-3 pt-4">
              <button type="submit"
                class="bg-violet-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-violet-700 transition-colors">
                {{ profile ? 'Atualizar' : 'Criar' }}
              </button>
              <a href="/profiles" class="px-4 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors">
                Cancelar
              </a>
            </div>
          </div>
        </form>
      </div>
    </main>
  </div>

  <script>
  function toggleSidebar() {
    const sidebar = document.getElementById('sidebar')
    const overlay = document.getElementById('sidebar-overlay')
    sidebar.classList.toggle('-translate-x-full')
    overlay.classList.toggle('hidden')
  }
  </script>
</body>
</html>